#include <stdio.h>
#include <stdlib.h>

// Definição da Struct para agrupar as informações em uma estrutura
struct Territorio {
    char nome[30];
    char cor[20];
    int tropas;
};

int main() {

    // Vetor para Armazenar 5 territórios
    struct Territorio territorios[5];
    
    printf("=================================\n");

    printf("\nVamos cadastrar os 5 territorios iniciais do nosso mundo.\n");

    // ENTRADA DE DADOS
    // Loop para cadastrar os 5 territórios
    for(int i = 0; i < 5; i++) {

        printf("\n--- Cadastrando Territorio %d ---\n", i + 1);

        // Leitura do nome
        printf("\nNome do Territorio: ");
        scanf(" %[^\n]", territorios[i].nome);

        // Leitura da cor
        printf("Cor do Territorio: ");
        scanf("%s", territorios[i].cor);

        // Leitura das tropas
        printf("Numero de Tropas: ");
        scanf("%d",&territorios[i].tropas);
    }

    printf("\nCadastro inicial concluido com sucesso!\n");
    printf("=======================================\n");
    printf("   MAPA DO MUNDO - ESTADO ATUAL\n");
    printf("=======================================\n");

    // Loop para mostrar os dados cadastrados
    for (int i = 0; i < 5; i++) {
        printf("\nTERRITORIO: %d\n", i + 1);
        printf(" - Nome: %s\n", territorios[i].nome);
        printf(" - Dominado por: Exercito %s\n", territorios[i].cor);
        printf(" - Tropas: %d\n", territorios[i].tropas);
    }
    printf("=================================");

    return 0;
}
